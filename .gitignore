# Raw/private logs and captures
logs/raw/
logs/private/
*.log

# Binary capture/build outputs
*.bin
*.elf
*.map
*.hex
*.raw
*.capture
*.pcap
*.pcapng

# Sensitive or stick-specific firmware dumps
*full_flash*.bin
*nvs*.bin
*known-good*.bin
*spd-dump*.bin

# Private source/reference material
sources/private/
sources/**/*.pdf
*.pdf

# Bulky/raw media
assets/raw/
assets/**/*.raw
assets/**/*.mov
assets/**/*.mp4

# OS/editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# Generic build/cache artifacts
__pycache__/
*.pyc
node_modules/
dist/
build/

# PlatformIO build artifacts
.pio/
.pioenvs/
.piolibdeps/

# Local release build output
release-artifacts/
